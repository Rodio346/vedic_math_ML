# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# Benchmark outputs (regenerated by python -m vedic_benchmark.main)
vedic_benchmark/results/*
!vedic_benchmark/results/.gitkeep

# Phase 2A build and generated CSV
phase2a/build/
phase2a/results/*
!phase2a/results/.gitkeep

# Phase 2B generated CSV
phase2b/results/*
!phase2b/results/.gitkeep

# Phase 3 build and generated CSV
phase3/build/
phase3/results/*
!phase3/results/.gitkeep

# Optional chart and run logs
*.png
vedic_benchmark/results/*.log

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDE (local settings only)
.idea/
.vscode/
*.swp
*.swo
*~

# Cursor (local workspace state)
.cursor/

# Environment secrets
.env
.env.*
!.env.example
